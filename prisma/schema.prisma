generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  imageNumbers String?  // Will store comma-separated list or JSON
  notes        String?
  createdAt    DateTime @default(now())
}

model Order {
  id            Int      @id @default(autoincrement())
  amount        Float
  firstName     String
  lastName      String
  email         String
  imageNumbers  String?
  notes         String?
  paymentMethod String   // 'bar' oder 'paypal'
  status        String   // 'pending', 'paid', 'cancelled'
  paypalOrderId String?  // falls wir offizielle PayPal API nutzen
  createdAt     DateTime @default(now())
}

model EmailSettings {
  id           Int     @id @default(autoincrement())
  enabled      Boolean @default(false)
  smtpHost     String  @default("")
  smtpPort     Int     @default(587)
  smtpUser     String  @default("")
  smtpPassword String  @default("")
  smtpSecure   Boolean @default(false)
  fromName     String  @default("")
  fromEmail    String  @default("")
  subject      String  @default("Deine Bestellbestätigung")
  bodyHtml     String  @default("<p>Vielen Dank für deine Bestellung!</p>")
}
